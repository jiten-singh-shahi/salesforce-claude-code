{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://scc-universal/schemas/plugin.schema.json",
  "title": "SCC Plugin Manifest",
  "description": "JSON Schema for plugin.json — describes the SCC plugin for Claude Code and Cursor marketplaces",
  "type": "object",
  "required": ["name", "version", "description"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema reference URI"
    },
    "name": {
      "type": "string",
      "description": "Package/plugin name (kebab-case)",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "Semantic version string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "displayName": {
      "type": "string",
      "description": "Human-readable display name for the plugin",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "description": "Short plugin description shown in the marketplace",
      "minLength": 10,
      "maxLength": 300
    },
    "author": {
      "oneOf": [
        {
          "type": "string",
          "description": "Plugin author name or organization"
        },
        {
          "type": "object",
          "description": "Plugin author details",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "url": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        }
      ]
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "keywords": {
      "type": "array",
      "description": "Searchable keywords for marketplace discovery",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 20
    },
    "logo": {
      "type": "string",
      "description": "Relative path to the plugin logo image (SVG or PNG)"
    },
    "engines": {
      "type": "object",
      "description": "Required harness versions",
      "properties": {
        "claude-code": {
          "type": "string",
          "description": "Required Claude Code version (semver range)"
        },
        "node": {
          "type": "string",
          "description": "Required Node.js version (semver range)"
        }
      }
    },
    "main": {
      "type": "string",
      "description": "Relative path to the primary plugin entry file",
      "minLength": 1
    },
    "agents": {
      "oneOf": [
        {
          "type": "string",
          "description": "Relative path to agents directory"
        },
        {
          "type": "array",
          "description": "Array of relative paths to individual agent files",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "skills": {
      "type": "string",
      "description": "Relative path to skills directory"
    },
    "hooks": {
      "type": "string",
      "description": "Relative path to hooks configuration file"
    },
    "mcpServers": {
      "type": "string",
      "description": "Relative path to MCP servers configuration file"
    },
    "commands": {
      "type": "string",
      "description": "Relative path to commands directory"
    },
    "rules": {
      "type": "string",
      "description": "Relative path to rules directory"
    },
    "repository": {
      "oneOf": [
        {
          "type": "string",
          "description": "Repository URL"
        },
        {
          "type": "object",
          "description": "Source repository information",
          "properties": {
            "type": { "type": "string", "enum": ["git", "svn"] },
            "url": { "type": "string" }
          }
        }
      ]
    },
    "homepage": {
      "type": "string",
      "description": "Plugin homepage or documentation URL",
      "format": "uri"
    }
  }
}
