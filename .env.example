# Hook profile: minimal | standard | strict
SCC_HOOK_PROFILE=standard

# Disable specific hooks (comma-separated)
# SCC_DISABLED_HOOKS=session-start,auto-format

# Package manager override (auto-detected by default)
# CLAUDE_PACKAGE_MANAGER=npm

# Salesforce org alias for default operations
# SF_ORG_ALIAS=MyDevOrg

# Salesforce scratch org duration (days)
# SF_SCRATCH_ORG_DURATION=30
